# ----------------
# LOCAL RULES
# ----------------
# This file intentionally does not come with signatures.  Put your local
# additions here.

alert icmp any any -> $HOME_NET any (msg: "Someone has pinged in the network"; sid:1000001; rev:1;)
alert tcp any any -> $HOME_NET 4444 (msg: “Connection to remote IP on port 4444"; sid:1000002; rev:1;)
